              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.quizId) {",
                  "    pm.collectionVariables.set('quizId', res.data.quizId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentId\": \"{{contentId}}\",\n  \"answers\": [\n    {\n      \"questionIndex\": 0,\n      \"selectedOption\": \"Option A\"\n    },\n    {\n      \"questionIndex\": 1,\n      \"selectedOption\": \"Option C\"\n    },\n    {\n      \"questionIndex\": 2,\n      \"selectedOption\": \"Option B\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/quiz/submit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quiz",
                "submit"
              ]
            },
            "description": "Submit quiz answers for auto-evaluation against the MCQs of a content document.\n\n**Access:** Private (student only)\n\n**Body Fields:**\n- `contentId` (string, required) – MongoDB ObjectId of the content with MCQs\n- `answers` (array, required, min 1 item) – Array of answer objects:\n  - `questionIndex` (number, required) – Zero-based index of the MCQ\n  - `selectedOption` (string, required) – The selected answer option\n\n**Note:** The `quizId` is automatically saved to the collection variable on success."
          },
          "response": [
            {
              "name": "Success",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Quiz submitted and evaluated successfully\",\n  \"data\": {\n    \"quizId\": \"661234567890abcdef789012\",\n    \"score\": 2,\n    \"totalQuestions\": 3,\n    \"percentage\": 67,\n    \"answers\": [\n      {\n        \"questionIndex\": 0,\n        \"selectedOption\": \"Option A\",\n        \"isCorrect\": true\n      },\n      {\n        \"questionIndex\": 1,\n        \"selectedOption\": \"Option C\",\n        \"isCorrect\": false\n      },\n      {\n        \"questionIndex\": 2,\n        \"selectedOption\": \"Option B\",\n        \"isCorrect\": true\n      }\n    ]\n  }\n}"
            },
            {
              "name": "Error - No MCQs",
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"This content does not have any MCQs to attempt\"\n}"
            }
          ]
        },
        {
          "name": "Get Quiz By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
